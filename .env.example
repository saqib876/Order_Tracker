# ─────────────────────────────────────────────
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git
# ─────────────────────────────────────────────

# Supabase — get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Shopify Webhook Secret — get from: Shopify Admin → Settings → Notifications → Webhooks
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret_here

# PostEx — public tracking API, no key needed

# Cron job secret — make this a long random string, e.g. openssl rand -hex 32
CRON_SECRET=your_random_cron_secret_here
